/* 对齐网页版：玻璃卡、灰蓝渐变底、slate 文字色 */

.scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 48rpx;
}

.glass {
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(15, 23, 42, 0.07);
}

.header {
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 20rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #0f172a;
  letter-spacing: -0.02em;
}

.header-row {
  margin-top: 24rpx;
}

.btn-summary {
  display: inline-block;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #1e293b;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.45);
}

.tabs {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 12rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 12rpx;
  font-size: 26rpx;
  border-radius: 20rpx;
  color: #475569;
  background: rgba(255, 255, 255, 0.35);
}

.tab-on {
  background: rgba(255, 255, 255, 0.88);
  color: #0f172a;
  font-weight: 500;
}

.section-hint {
  font-size: 22rpx;
  color: #64748b;
  margin: 0 8rpx 16rpx;
  padding-left: 4rpx;
}

.matrix {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.cell {
  width: 48%;
  margin-bottom: 20rpx;
  padding: 28rpx 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.cell-icon {
  font-size: 52rpx;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.cell-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #334155;
  line-height: 1.35;
}

.note {
  margin-top: 8rpx;
  padding: 24rpx;
}

.note-text {
  display: block;
  font-size: 22rpx;
  line-height: 1.55;
  color: #64748b;
}
